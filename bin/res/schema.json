{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Game Asset Loader Schema",
  "description": "Schema for loading game entity assets with components as discriminated variants",
  "type": "object",
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "components"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "const": "Entity"
          },
          "components": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "type"
              ],
              "oneOf": [
                {
                  "properties": {
                    "type": {
                      "const": "TransformComponent"
                    },
                    "pos": {
                      "type": "object",
                      "properties": {
                        "x": {
                          "type": "number"
                        },
                        "y": {
                          "type": "number"
                        }
                      }
                    },
                    "rot": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "SpriteComponent"
                    },
                    "scaling": {
                      "type": "number"
                    },
                    "subSprites": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "gridPos": {
                            "type": "object",
                            "properties": {
                              "x": {
                                "type": "number"
                              },
                              "y": {
                                "type": "number"
                              }
                            }
                          },
                          "layers": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "path": {
                                  "type": "string"
                                },
                                "layer": {
                                  "type": "string",
                                  "enum": [
                                    "Bottom",
                                    "Floor",
                                    "Wall",
                                    "Turret",
                                    "Item",
                                    "Top"
                                  ]
                                },
                                "offset": {
                                  "type": "object",
                                  "properties": {
                                    "x": {
                                      "type": "number"
                                    },
                                    "y": {
                                      "type": "number"
                                    }
                                  }
                                },
                                "rot": {
                                  "type": "number"
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "CameraComponent"
                    },
                    "zoom": {
                      "type": "number"
                    },
                    "rot": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "SeekPrimaryTargetTag"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "PrimaryTargetTag"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "WorldMapTag"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "HealthComponent"
                    },
                    "health": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "ContactDamageComponent"
                    },
                    "damage": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "BulletDamageComponent"
                    },
                    "damage": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "LifetimeComponent"
                    },
                    "timeLeft": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "PlayerComponent"
                    },
                    "accel": {
                      "type": "number"
                    },
                    "maxSpeed": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "BodyComponent"
                    },
                    "bodyType": {
                      "type": "string",
                      "enum": [
                        "dynamic",
                        "static",
                        "kinematic"
                      ]
                    },
                    "linearDamping": {
                      "type": "number"
                    },
                    "angularDamping": {
                      "type": "number"
                    },
                    "gravityScale": {
                      "type": "number"
