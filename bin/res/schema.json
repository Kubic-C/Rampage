                    "isBullet": {
                      "type": "boolean"
                    },
                    "enableSleep": {
                      "type": "boolean"
                    },
                    "shapes": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "enableContactEvents": {
                            "type": "boolean"
                          },
                          "enableSensorEvents": {
                            "type": "boolean"
                          },
                          "density": {
                            "type": "number"
                          },
                          "friction": {
                            "type": "number"
                          },
                          "restitution": {
                            "type": "number"
                          },
                          "isSensor": {
                            "type": "boolean"
                          },
                          "categoryMask": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "collisionMask": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          },
                          "shape": {
                            "type": "object",
                            "required": [
                              "shapeType"
                            ],
                            "properties": {
                              "shapeType": {
                                "type": "string",
                                "enum": [
                                  "Circle",
                                  "Polygon"
                                ]
                              },
                              "radius": {
                                "type": "number",
                                "default": 0
                              },
                              "vertices": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "required": [
                                    "x",
                                    "y"
                                  ],
                                  "properties": {
                                    "x": {
                                      "type": "number"
                                    },
                                    "y": {
                                      "type": "number"
                                    }
                                  }
                                },
                                "maxItems": 8
                              }
                            }
                          }
                        }
                      }
                    }
