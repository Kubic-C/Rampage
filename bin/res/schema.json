                        "x": {
                          "type": "integer"
                        },
                        "y": {
                          "type": "integer"
                        }
                      }
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "TurretComponent"
