                    "fireRate": {
                      "type": "number"
                    },
                    "timeSinceLastShot": {
                      "type": "number"
                    },
                    "radius": {
                      "type": "number"
                    },
                    "rot": {
                      "type": "number"
                    },
                    "turnSpeed": {
                      "type": "number"
                    },
                    "shootRange": {
                      "type": "number"
                    },
                    "stopRange": {
                      "type": "number"
                    },
                    "muzzleVelocity": {
                      "type": "number"
                    },
                    "bulletRadius": {
                      "type": "number"
                    },
                    "bulletDamage": {
                      "type": "number"
                    },
                    "bulletHealth": {
                      "type": "number"
                    },
                    "summon": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "SpawnerComponent"
                    },
                    "spawn": {
                      "type": "string"
