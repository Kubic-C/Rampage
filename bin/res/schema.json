                    "spawnableRadius": {
                      "type": "number"
                    },
                    "spawnCount": {
                      "type": "integer",
                      "minimum": 0
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "CircleRenderComponent"
                    },
                    "radius": {
                      "type": "number"
                    },
                    "offset": {
                      "type": "object",
                      "properties": {
                        "x": {
                          "type": "number"
                        },
                        "y": {
                          "type": "number"
                        }
                      }
                    },
                    "z": {
                      "type": "number"
                    },
                    "color": {
                      "type": "object",
                      "properties": {
                        "r": {
                          "type": "number"
                        },
                        "g": {
                          "type": "number"
                        },
                        "b": {
                          "type": "number"
                        }
                      }
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "RectangleRenderComponent"
                    },
                    "hw": {
                      "type": "number"
                    },
                    "hh": {
                      "type": "number"
                    },
                    "z": {
                      "type": "number"
                    },
                    "color": {
                      "type": "object",
                      "properties": {
                        "r": {
                          "type": "number"
                        },
                        "g": {
                          "type": "number"
                        },
                        "b": {
                          "type": "number"
                        }
                      }
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "ItemComponent"
                    },
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "maxStackSize": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "stackCost": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "isUnique": {
                      "type": "boolean"
                    },
                    "iconAsset": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "InventoryComponent"
                    },
                    "cols": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "rows": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "count": {
                            "type": "integer",
                            "minimum": 0
                          },
                          "itemEntityName": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  },
                  "required": [
                    "type"
                  ]
                },
                {
                  "properties": {
                    "type": {
                      "const": "InventoryViewComponent"
                    },
                    "name": {
                      "type": "string"
                    },
                    "pos": {
                      "type": "object",
                      "properties": {
                        "x": {
                          "type": "number"
                        },
                        "y": {
                          "type": "number"
                        }
                      }
                    },
                    "isVisible": {
                      "type": "boolean"
                    },
                    "isInteractable": {
                      "type": "boolean"
                    },
                    "padding": {
                      "type": "object",
                      "properties": {
                        "x": {
                          "type": "number"
                        },
                        "y": {
                          "type": "number"
                        }
                      }
                    },
                    "slotSize": {
                      "type": "number"
                    },
                    "rounding": {
                      "type": "number"
