                      "minItems": 4,
                      "maxItems": 4
                    },
                    "borderColor": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "minItems": 4,
                      "maxItems": 4
                    },
                    "emptySlotColor": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "minItems": 4,
                      "maxItems": 4
                    },
                    "textColor": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "minItems": 4,
                      "maxItems": 4
                    },
                    "hoverSlotColor": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "minItems": 4,
                      "maxItems": 4
                    },
                    "dragHoverSlotColor": {
                      "type": "array",
                      "items": {
                        "type": "integer"
                      },
                      "minItems": 4,
                      "maxItems": 4
                    }
